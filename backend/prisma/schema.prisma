generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum GemStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())

  listings     Gem[]     @relation("SellerListings")
  orders       Order[]   @relation("BuyerOrders")
  sentMessages Message[] @relation("SentMessages")
  recvMessages Message[] @relation("ReceivedMessages")
  reviews      Review[]
}

model Gem {
  id            String    @id @default(cuid())
  sellerId      String
  title         String
  description   String
  type          String
  weightCarats  Decimal   @db.Decimal(10, 2)
  color         String
  clarity       String
  origin        String
  certification String?
  price         Decimal   @db.Decimal(10, 2)
  status        GemStatus @default(PENDING)
  createdAt     DateTime  @default(now())

  seller        User      @relation("SellerListings", fields: [sellerId], references: [id])
  orderItems    OrderItem[]
}

model Order {
  id          String      @id @default(cuid())
  buyerId     String
  totalAmount Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())

  buyer       User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id      String  @id @default(cuid())
  orderId String
  gemId   String
  price   Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id])
  gem     Gem     @relation(fields: [gemId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  message    String
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}
